generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Plans ─────────────────────────────────────────────────────────────────────

enum Plan {
  FREE
  STARTER
  PRO
}

// ── Organizations (Multi-tenancy) ──────────────────────────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  isActive  Boolean  @default(true)
  // Subscription plan
  plan          Plan      @default(FREE)
  planExpiresAt DateTime? @map("plan_expires_at")
  // Profile fields
  logoUrl     String?
  website     String?
  instagram   String?
  phone       String?
  address     String?
  category    String?
  description String?
  whatsapp    String?
  // Extended config
  deliveryFee    Decimal? @map("delivery_fee")
  paymentMethods Json?   @map("payment_methods")
  businessHours  Json?   @map("business_hours")
  modalities     Json?   @map("modalities")
  colorPrimary   String? @map("color_primary")
  colorSecondary String? @map("color_secondary")
  colorAccent    String? @map("color_accent")
  coverImageUrl  String? @map("cover_image_url")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                User[]
  suppliers            Supplier[]
  ingredients          Ingredient[]
  productCategories    ProductCategory[]
  products             Product[]
  customers            Customer[]
  repartidores         Repartidor[]
  sales                Sale[]
  stockMovements       StockMovement[]
  incomeEntries        IncomeEntry[]
  expenseCategories    ExpenseCategory[]
  expenses             Expense[]
  cashSessions         CashSession[]
  supplierInvoices     SupplierInvoice[]
  supplierPayments     SupplierPayment[]
  employees            Employee[]
  timeLogs             TimeLog[]
  workSchedules        WorkSchedule[]
  restDays             RestDay[]
  preparations         Preparation[]
  preparationMovements PreparationMovement[]
  combos               Combo[]
  purchaseOrders       PurchaseOrder[]
  ingredientCostHistory IngredientCostHistory[]

  @@map("organizations")
}

// ── Core business models ───────────────────────────────────────────────────────

model Supplier {
  id             String  @id @default(cuid())
  organizationId String  @map("organization_id")
  name           String
  phone          String?
  email          String?
  notes          String?
  paymentTerms   String  @default("ON_DELIVERY")
  creditDays     Int     @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization          Organization            @relation(fields: [organizationId], references: [id])
  ingredients           Ingredient[]
  invoices              SupplierInvoice[]
  supplierPayments      SupplierPayment[]
  purchaseOrders        PurchaseOrder[]
  ingredientCostHistory IngredientCostHistory[]

  @@index([organizationId])
  @@map("suppliers")
}

model Ingredient {
  id                 String   @id @default(cuid())
  organizationId     String   @map("organization_id")
  name               String
  unit               String
  onHand             Decimal  @default(0)
  minQty             Decimal  @default(0)
  costPerUnit        Decimal  @default(0)
  currency           String   @default("ARS")
  supplierId         String?
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  organization           Organization            @relation(fields: [organizationId], references: [id])
  supplier               Supplier?               @relation(fields: [supplierId], references: [id])
  productIngredients     ProductIngredient[]
  stockMovements         StockMovement[]
  preparationIngredients PreparationIngredient[]
  purchaseOrderItems     PurchaseOrderItem[]
  costHistory            IngredientCostHistory[]

  @@index([organizationId, isActive])
  @@index([supplierId])
  @@map("ingredients")
}

model ProductCategory {
  id             String  @id @default(cuid())
  organizationId String  @map("organization_id")
  name           String
  color          String  @default("#6B7280")

  organization Organization @relation(fields: [organizationId], references: [id])
  products     Product[]

  @@unique([name, organizationId])
  @@index([organizationId])
  @@map("product_categories")
}

model Product {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  name           String
  sku            String?
  salePrice      Decimal  @default(0)
  costPrice      Decimal  @default(0)
  currency       String   @default("ARS")
  categoryId     String?  @map("category_id")
  isActive       Boolean  @default(true)
  imageUrl       String?  @map("image_url")
  description    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id])
  category     ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  ingredients  ProductIngredient[]
  preparations ProductPreparation[]
  saleItems    SaleItem[]
  combos       ComboProduct[]

  @@unique([sku, organizationId])
  @@index([organizationId, isActive])
  @@index([categoryId])
  @@map("products")
}

model ProductIngredient {
  productId    String
  ingredientId String
  qty          Decimal
  unit         String
  wastagePct   Decimal  @default(0)

  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredientId], references: [id])

  @@id([productId, ingredientId])
  @@map("product_ingredients")
}

model Repartidor {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  name           String
  phone          String?
  isActive       Boolean  @default(true)  @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt      @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  sales        Sale[]

  @@index([organizationId, isActive])
  @@map("repartidores")
}

model Customer {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  name           String
  phone          String?
  email          String?
  address        String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  sales        Sale[]

  @@unique([phone, organizationId])
  @@index([organizationId])
  @@index([phone])
  @@map("customers")
}

model Sale {
  id              String    @id @default(cuid())
  organizationId  String    @map("organization_id")
  date            DateTime  @default(now())
  notes           String?
  total           Decimal   @default(0)
  customerId      String?   @map("customer_id")
  customerName    String?   @map("customer_name")
  orderType       String    @default("SALON")   @map("order_type")
  isPaid          Boolean   @default(false)      @map("is_paid")
  deliveryAddress String?   @map("delivery_address")
  orderStatus      String    @default("NUEVO")   @map("order_status")
  dailyOrderNumber Int?      @map("daily_order_number")
  repartidorId     String?   @map("repartidor_id")
  deliveryFee      Decimal?  @map("delivery_fee")
  startedAt        DateTime? @map("started_at")
  readyAt          DateTime? @map("ready_at")
  deliveredAt      DateTime? @map("delivered_at")
  delayMinutes     Int?      @map("delay_minutes")
  createdAt        DateTime  @default(now())

  organization   Organization    @relation(fields: [organizationId], references: [id])
  customer       Customer?       @relation(fields: [customerId], references: [id], onDelete: SetNull)
  repartidor     Repartidor?     @relation(fields: [repartidorId], references: [id], onDelete: SetNull)
  items          SaleItem[]
  stockMovements StockMovement[]
  payments       SalePayment[]
  combos         SaleCombo[]

  @@index([organizationId, date])
  @@index([customerId])
  @@map("sales")
}

model SaleItem {
  saleId        String
  productId     String
  quantity      Decimal
  isUnavailable Boolean @default(false) @map("is_unavailable")

  sale    Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@id([saleId, productId])
  @@index([productId])
  @@map("sale_items")
}

model SalePayment {
  id            String  @id @default(cuid())
  saleId        String
  paymentMethod String
  amount        Decimal

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@map("sale_payments")
}

model StockMovement {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  ingredientId   String
  type           String
  delta          Decimal
  reason         String?
  refId          String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  ingredient   Ingredient   @relation(fields: [ingredientId], references: [id])
  sale         Sale?        @relation(fields: [refId], references: [id])

  @@index([organizationId, type, createdAt])
  @@index([ingredientId, type])
  @@map("stock_movements")
}

model IncomeEntry {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  amount         Decimal
  currency       String   @default("ARS")
  date           DateTime @default(now())
  paymentMethod  String
  description    String
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, date])
  @@map("income_entries")
}

model ExpenseCategory {
  id             String  @id @default(cuid())
  organizationId String  @map("organization_id")
  name           String
  color          String  @default("#6B7280")

  organization Organization @relation(fields: [organizationId], references: [id])
  expenses     Expense[]

  @@unique([name, organizationId])
  @@index([organizationId])
  @@map("expense_categories")
}

model Expense {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  amount         Decimal
  currency       String   @default("ARS")
  date           DateTime @default(now())
  description    String
  categoryId     String?
  cashSessionId  String?  @map("cash_session_id")
  paymentMethod  String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id])
  category     ExpenseCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  cashSession  CashSession?     @relation(fields: [cashSessionId], references: [id], onDelete: SetNull)

  @@index([organizationId, date])
  @@index([categoryId])
  @@index([cashSessionId])
  @@map("expenses")
}

model CashSession {
  id             String    @id @default(cuid())
  organizationId String    @map("organization_id")
  openedAt       DateTime  @default(now())
  closedAt       DateTime?
  openingBalance Decimal   @default(0)
  closingBalance Decimal?
  notes          String?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  expenses     Expense[]

  @@index([organizationId, closedAt])
  @@map("cash_sessions")
}

model SupplierInvoice {
  id             String    @id @default(cuid())
  organizationId String    @map("organization_id")
  supplierId     String
  amount         Decimal
  currency       String    @default("ARS")
  date           DateTime  @default(now())
  dueDate        DateTime?
  invoiceNumber  String?
  imageUrl       String?
  notes          String?
  status         String    @default("PENDING")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization     Organization      @relation(fields: [organizationId], references: [id])
  supplier         Supplier          @relation(fields: [supplierId], references: [id])
  supplierPayments SupplierPayment[]

  @@index([organizationId, supplierId])
  @@index([status])
  @@map("supplier_invoices")
}

model SupplierPayment {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  supplierId     String
  invoiceId      String?
  amount         Decimal
  currency       String   @default("ARS")
  date           DateTime @default(now())
  paymentMethod  String
  notes          String?
  createdAt      DateTime @default(now())

  organization Organization     @relation(fields: [organizationId], references: [id])
  supplier     Supplier         @relation(fields: [supplierId], references: [id])
  invoice      SupplierInvoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([organizationId, supplierId])
  @@index([date])
  @@map("supplier_payments")
}

model Employee {
  id             String    @id @default(cuid())
  organizationId String    @map("organization_id")
  firstName      String
  lastName       String
  role           String?
  hourlyRate     Decimal   @default(0)
  phone          String?
  email          String?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization  Organization   @relation(fields: [organizationId], references: [id])
  timeLogs      TimeLog[]
  user          User?
  workSchedules WorkSchedule[]
  restDays      RestDay[]

  @@index([organizationId, isActive])
  @@map("employees")
}

model TimeLog {
  id             String    @id @default(cuid())
  organizationId String    @map("organization_id")
  employeeId     String
  checkIn        DateTime
  checkOut       DateTime?
  duration       Decimal?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  employee     Employee     @relation(fields: [employeeId], references: [id])

  @@index([organizationId, employeeId, checkIn])
  @@map("time_logs")
}

model WorkSchedule {
  id             String @id @default(cuid())
  organizationId String @map("organization_id")
  employeeId     String
  dayOfWeek      Int
  shiftIndex     Int    @default(0)
  startTime      String
  endTime        String

  organization Organization @relation(fields: [organizationId], references: [id])
  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, dayOfWeek, shiftIndex])
  @@index([organizationId, employeeId])
  @@map("work_schedules")
}

model RestDay {
  id             String @id @default(cuid())
  organizationId String @map("organization_id")
  employeeId     String
  date           String
  notes          String?

  organization Organization @relation(fields: [organizationId], references: [id])
  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@index([organizationId, employeeId])
  @@index([date])
  @@map("rest_days")
}

// ── Preparaciones ─────────────────────────────────────────────────────────────

model Preparation {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  name           String
  unit           String
  yieldQty       Decimal  @default(1)
  wastagePct     Decimal  @default(0) @map("wastage_pct")
  onHand         Decimal  @default(0)
  costPrice      Decimal  @default(0)
  notes          String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization       Organization            @relation(fields: [organizationId], references: [id])
  ingredients        PreparationIngredient[]
  subPreparations    PreparationSubPrep[]    @relation("ParentPrep")
  usedInPreparations PreparationSubPrep[]    @relation("SubPrep")
  productBOMLinks    ProductPreparation[]
  movements          PreparationMovement[]

  @@index([organizationId, isActive])
  @@map("preparations")
}

model PreparationSubPrep {
  preparationId String
  subPrepId     String
  qty           Decimal
  unit          String
  wastagePct    Decimal @default(0)

  preparation Preparation @relation("ParentPrep", fields: [preparationId], references: [id], onDelete: Cascade)
  subPrep     Preparation @relation("SubPrep", fields: [subPrepId], references: [id])

  @@id([preparationId, subPrepId])
  @@map("preparation_sub_preps")
}

model PreparationIngredient {
  preparationId String
  ingredientId  String
  qty           Decimal
  unit          String
  wastagePct    Decimal @default(0)

  preparation Preparation @relation(fields: [preparationId], references: [id], onDelete: Cascade)
  ingredient  Ingredient  @relation(fields: [ingredientId], references: [id])

  @@id([preparationId, ingredientId])
  @@map("preparation_ingredients")
}

model PreparationMovement {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  preparationId  String
  type           String
  delta          Decimal
  reason         String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  preparation  Preparation  @relation(fields: [preparationId], references: [id])

  @@index([organizationId, preparationId, type])
  @@map("preparation_movements")
}

model ProductPreparation {
  productId     String
  preparationId String
  qty           Decimal
  unit          String
  wastagePct    Decimal @default(0)

  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  preparation Preparation @relation(fields: [preparationId], references: [id])

  @@id([productId, preparationId])
  @@map("product_preparations")
}

// ── Combos ────────────────────────────────────────────────────────────────────

model Combo {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  name           String
  sku            String?
  salePrice      Decimal  @default(0)
  currency       String   @default("ARS")
  isActive       Boolean  @default(true)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization   @relation(fields: [organizationId], references: [id])
  products     ComboProduct[]
  saleCombos   SaleCombo[]

  @@unique([sku, organizationId])
  @@index([organizationId, isActive])
  @@map("combos")
}

model ComboProduct {
  comboId   String
  productId String
  quantity  Decimal @default(1)

  combo   Combo   @relation(fields: [comboId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@id([comboId, productId])
  @@map("combo_products")
}

model SaleCombo {
  id       String  @id @default(cuid())
  saleId   String
  comboId  String
  quantity Decimal @default(1)
  price    Decimal

  sale  Sale  @relation(fields: [saleId], references: [id], onDelete: Cascade)
  combo Combo @relation(fields: [comboId], references: [id])

  @@index([saleId])
  @@map("sale_combos")
}

// ── Purchase Orders ───────────────────────────────────────────────────────────

model PurchaseOrder {
  id                  String    @id @default(cuid())
  organizationId      String    @map("organization_id")
  supplierId          String    @map("supplier_id")
  number              String
  status              String    @default("DRAFT")
  expectedTotal       Decimal   @default(0)  @map("expected_total")
  actualTotal         Decimal?              @map("actual_total")
  notes               String?
  sentAt              DateTime?             @map("sent_at")
  receivedAt          DateTime?             @map("received_at")
  isPartial           Boolean   @default(false) @map("is_partial")
  expectedDeliveryAt  DateTime?             @map("expected_delivery_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt      @map("updated_at")

  organization  Organization            @relation(fields: [organizationId], references: [id])
  supplier      Supplier                @relation(fields: [supplierId], references: [id])
  items         PurchaseOrderItem[]
  invoices      PurchaseOrderInvoice[]
  costHistory   IngredientCostHistory[]

  @@unique([organizationId, number])
  @@index([organizationId, status])
  @@index([supplierId])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id                      String   @id @default(cuid())
  purchaseOrderId         String   @map("purchase_order_id")
  ingredientId            String   @map("ingredient_id")
  ingredientNameSnapshot  String   @map("ingredient_name_snapshot")
  unit                    String
  expectedQty             Decimal  @map("expected_qty")
  receivedQty             Decimal? @map("received_qty")
  expectedUnitCost        Decimal  @map("expected_unit_cost")
  actualUnitCost          Decimal? @map("actual_unit_cost")
  expectedSubtotal        Decimal  @map("expected_subtotal")
  actualSubtotal          Decimal? @map("actual_subtotal")
  notes                   String?

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  ingredient    Ingredient    @relation(fields: [ingredientId], references: [id])

  @@index([purchaseOrderId])
  @@index([ingredientId])
  @@map("purchase_order_items")
}

model PurchaseOrderInvoice {
  id              String   @id @default(cuid())
  purchaseOrderId String   @map("purchase_order_id")
  fileUrl         String   @map("file_url")
  fileType        String?  @map("file_type")
  fileName        String   @map("file_name")
  uploadedAt      DateTime @default(now()) @map("uploaded_at")

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId])
  @@map("purchase_order_invoices")
}

model IngredientCostHistory {
  id              String   @id @default(cuid())
  organizationId  String   @map("organization_id")
  ingredientId    String   @map("ingredient_id")
  supplierId      String?  @map("supplier_id")
  purchaseOrderId String?  @map("purchase_order_id")
  previousCost    Decimal  @map("previous_cost")
  newCost         Decimal  @map("new_cost")
  quantity        Decimal?
  effectiveDate   DateTime @default(now()) @map("effective_date")
  createdAt       DateTime @default(now()) @map("created_at")

  organization  Organization   @relation(fields: [organizationId], references: [id])
  ingredient    Ingredient     @relation(fields: [ingredientId], references: [id])
  supplier      Supplier?      @relation(fields: [supplierId], references: [id])
  purchaseOrder PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)

  @@index([ingredientId, effectiveDate])
  @@index([organizationId])
  @@map("ingredient_cost_history")
}

// ── Users / Auth ───────────────────────────────────────────────────────────────

model User {
  id             String   @id @default(cuid())
  username       String   @unique
  password       String
  role           String   @default("EMPLEADO") // SUPERADMIN | ADMIN | ENCARGADO | CAJERA | EMPLEADO
  isActive       Boolean  @default(true)
  organizationId String?  @map("organization_id") // null = SUPERADMIN
  employeeId     String?  @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id])
  employee     Employee?     @relation(fields: [employeeId], references: [id], onDelete: SetNull)

  @@index([username])
  @@index([organizationId])
  @@map("users")
}

// ── Schedules ─────────────────────────────────────────────────────────────────

// WorkSchedule and RestDay already defined above with organizationId
